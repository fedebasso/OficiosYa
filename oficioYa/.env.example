# OficioYa — Variables de entorno
#
# Copiá este archivo como .env y completá los valores.
# Sin este archivo la app corre en MODO DEMO automáticamente.
#
# Modo demo: usa datos mock locales, no requiere internet ni Supabase.
# Modo producción: conecta con Supabase real.

# ── Supabase (requerido para modo producción) ──────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
